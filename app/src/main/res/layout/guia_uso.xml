<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guía de Uso"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="24dp" />

        <!-- Paso 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. ¿Cómo acceder a mis cursos?"
            android:textStyle="bold"
            android:textColor="#005596"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dirígete al menú lateral y selecciona la opción 'Cursos'. Allí verás la lista de materias en las que estás matriculado actualmente."
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- Paso 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. ¿Cómo ver mis tareas pendientes?"
            android:textStyle="bold"
            android:textColor="#005596"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="En el 'Tablero' principal encontrarás un resumen de las actividades próximas a vencer. También puedes revisar el 'Calendario' para una vista mensual."
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- Paso 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Bandeja de entrada"
            android:textStyle="bold"
            android:textColor="#005596"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Utiliza la bandeja de entrada para comunicarte con tus docentes. Recuerda revisar tus notificaciones diariamente."
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <!-- Contacto Soporte -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:padding="16dp"
            android:text="¿Necesitas más ayuda?\nContáctanos: soporte@sise.edu.pe"
            android:gravity="center"
            android:textColor="#333333" />

    </LinearLayout>
</ScrollView>